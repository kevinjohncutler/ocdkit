# Copy to scripts/coverage_cross_device.env (untracked) and fill in.
# Sourced automatically by scripts/coverage_cross_device.sh if present.

# Absolute path to this repo on the local machine
export OCDKIT_LOCAL_ROOT="/path/to/ocdkit"

# Absolute path to this repo on the remote (CUDA) machine
export OCDKIT_REMOTE_ROOT="/home/<user>/ocdkit"

# SSH target for the remote machine
export OCDKIT_REMOTE="user@host"
